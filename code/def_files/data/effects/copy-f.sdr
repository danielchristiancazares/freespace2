in vec4 fragTexCoord;
out vec4 fragOut0;

#ifdef VULKAN
#define LAYOUT_SET_BINDING(set_id, binding_id) layout(set = set_id, binding = binding_id)
#else
#define LAYOUT_SET_BINDING(set_id, binding_id)
#endif

#ifdef COPY_ARRAY
LAYOUT_SET_BINDING(1, 0) uniform sampler2DArray tex;
#else
LAYOUT_SET_BINDING(1, 1) uniform sampler2D tex;
#endif

void main()
{
#ifdef COPY_ARRAY
	fragOut0 = texture(tex, vec3(fragTexCoord.xy, 0));
#else
	fragOut0 = texture(tex, fragTexCoord.xy);
#endif
}
