in vec4 fragTexCoord;
out vec4 fragOut0;

#ifdef VULKAN
#define LAYOUT_SET_BINDING(set_id, binding_id) layout(set = set_id, binding = binding_id)
#else
#define LAYOUT_SET_BINDING(set_id, binding_id)
#endif

LAYOUT_SET_BINDING(1, 0) uniform sampler2D tex;
void main() {
	vec4 color = texture(tex, fragTexCoord.xy);
	fragOut0 = vec4(color.rgb, dot(color.rgb, vec3(0.299, 0.587, 0.114)) );
}
